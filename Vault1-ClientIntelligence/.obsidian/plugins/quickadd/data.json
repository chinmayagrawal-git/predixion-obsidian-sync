        "modelSource": "modelsDev"
      },
      {
        "name": "Gemini",
        "endpoint": "https://generativelanguage.googleapis.com",
        "apiKey": "",
        "models": [
          {
            "name": "gemini-1.5-pro",
            "maxTokens": 1000000
          },
          {

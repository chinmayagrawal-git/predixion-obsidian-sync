# Fireflies API key — Settings → API in the Fireflies dashboard.
# If left blank, fireflies_sync.py falls back to fixtures/fireflies_mock_response.json.
FIREFLIES_API_KEY=

# Gmail OAuth "Desktop app" client, downloaded from Google Cloud Console
# (APIs & Services → Credentials → Create Credentials → OAuth client ID → Desktop app).
# Substituted for the doc's outlook_sync.py / Microsoft Graph — no Outlook/Azure
# access was available for this build. See README.md for full setup steps.
GOOGLE_CREDENTIALS_FILE=credentials.json

# Auto-created on first run after the OAuth browser approval. Leave as-is.
GOOGLE_TOKEN_FILE=token.json

# Where daily_brief.py sends the brief. Substituted for the doc's Slack webhook
# push — no Slack workspace was available for this build.
DAILY_BRIEF_RECIPIENT=
